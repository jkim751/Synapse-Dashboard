generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Director {
  id    String   @id
  username String   @unique
  email    String?  @unique
  img      String?  
  name     String
  surname  String
  phone    String
}

model Admin {
  id       String   @id
  username String   @unique
  address  String
  birthday DateTime
  email    String?  @unique
  img      String?
  name     String
  phone    String?  @unique
  role     String   @default("admin")
  sex      UserSex
  surname  String
}

model Student {
  id            String                 @id
  username      String                 @unique
  name          String
  surname       String
  email         String?                @unique
  phone         String?                @unique
  address       String
  img           String?
  sex           UserSex
  createdAt     DateTime               @default(now())
  parentId      String?
  gradeId       Int
  birthday      DateTime
  xeroContactId String?
  school        String?
  updatedAt     DateTime               @updatedAt
  status        StudentStatus          @default(CURRENT)
  attendances   Attendance[]
  results       Result[]
  grade         Grade                  @relation(fields: [gradeId], references: [id])
  parent        Parent?                @relation(fields: [parentId], references: [id])
  classes       StudentClass[]
  statusHistory StudentStatusHistory[]

  StudentNote    StudentNote[]
  StudentTag     StudentTag[]
  makeupLessons  MakeupStudent[]
}

model Teacher {
  id              String            @id
  username        String            @unique
  name            String
  surname         String
  email           String?           @unique
  phone           String?           @unique
  address         String
  img             String?
  sex             UserSex
  createdAt       DateTime          @default(now())
  birthday        DateTime
  xeroEmployeeId  String?
  lessons         Lesson[]
  RecurringLesson RecurringLesson[]
  subjects        Subject[]         @relation("SubjectToTeacher")
}

model Parent {
  id            String      @id
  username      String      @unique
  name          String
  surname       String
  email         String?     @unique
  phone         String      @unique
  address       String
  createdAt     DateTime    @default(now())
  xeroContactId String?
  paymentType   PaymentType @default(CASH)
  students      Student[]
}

model Grade {
  id                 Int                 @id @default(autoincrement())
  level              Int                 @unique
  announcementGrades AnnouncementGrade[]
  classess           Class[]
  eventGrades        EventGrade[]
  students           Student[]
}

model Class {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  capacity        Int
  supervisorId    String?
  gradeId         Int
  announcements   Announcement[]
  grade           Grade             @relation(fields: [gradeId], references: [id])
  events          Event[]
  lessons         Lesson[]
  RecurringLesson RecurringLesson[]
  students        StudentClass[]
  chatThreads     ChatThread[]
}

model Subject {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  lessons         Lesson[]
  RecurringLesson RecurringLesson[]
  teachers        Teacher[]         @relation("SubjectToTeacher")
  subjectRate     SubjectRate?
}

model SubjectRate {
  id          String   @id @default(cuid())
  subjectId   Int      @unique
  subject     Subject  @relation(fields: [subjectId], references: [id])
  hourlyRate  Float?
  privateRate Float?
  groupRate   Float?
  hours       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("subject_rates")
}

model PaySheetEntry {
  id          String   @id @default(cuid())
  name        String
  classType   String?
  privateRate Float?
  groupRate   Float?
  hours       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pay_sheet_entries")
}

model WorkedHours {
  id          String   @id @default(cuid())
  teacherId   String
  date        DateTime @default(now())
  className   String
  hoursWorked Float
  attendees   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("worked_hours")
}

model Lesson {
  id                Int              @id @default(autoincrement())
  name              String
  startTime         DateTime
  endTime           DateTime
  recurringLessonId Int?
  subjectId         Int?
  classId           Int?
  teacherId         String?
  isCancelled       Boolean          @default(false)
  isMakeup          Boolean          @default(false)
  day               Day
  term              Int?
  year              Int?
  assessments       Assessment[]
  attendances       Attendance[]
  class             Class?           @relation(fields: [classId], references: [id])
  recurringLesson   RecurringLesson? @relation(fields: [recurringLessonId], references: [id], onDelete: Cascade)
  subject           Subject?         @relation(fields: [subjectId], references: [id])
  teacher           Teacher?         @relation(fields: [teacherId], references: [id])
  notifications     Notification[]
  makeupStudents    MakeupStudent[]
}

model MakeupStudent {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  studentId String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([lessonId, studentId])
  @@map("makeup_students")
}

model Assessment {
  id                Int            @id @default(autoincrement())
  title             String
  type              AssessmentType
  documents         String[]       @default([])
  lessonId          Int?
  recurringLessonId Int?
  lesson            Lesson?        @relation(fields: [lessonId], references: [id])
  recurringLesson   RecurringLesson? @relation(fields: [recurringLessonId], references: [id])
  results           Result[]
}

model Result {
  id           Int         @id @default(autoincrement())
  score        Int
  title        String
  assessmentId Int?
  studentId    String
  documents    String[]    @default([])
  assessment   Assessment? @relation(fields: [assessmentId], references: [id])
  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Attendance {
  id                Int              @id @default(autoincrement())
  date              DateTime
  present           Boolean
  studentId         String
  lessonId          Int?
  recurringLessonId Int?
  status            String?          @default("present")
  recordedByName    String?
  lesson            Lesson?          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  recurringLesson   RecurringLesson? @relation(fields: [recurringLessonId], references: [id], onDelete: Cascade)
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Event {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  classId     Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())
  class       Class?       @relation(fields: [classId], references: [id])
  eventGrades EventGrade[]
  eventUsers  EventUser[]
}

model EventUser {
  id      Int    @id @default(autoincrement())
  eventId Int
  userId  String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventGrade {
  id      Int   @id @default(autoincrement())
  eventId Int
  gradeId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  grade   Grade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([eventId, gradeId])
}

model Announcement {
  id                 Int                 @id @default(autoincrement())
  title              String
  description        String
  date               DateTime
  classId            Int?
  allParents         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now())
  class              Class?              @relation(fields: [classId], references: [id])
  announcementGrades AnnouncementGrade[]
  announcementUsers  AnnouncementUser[]
}

model AnnouncementUser {
  id             Int          @id @default(autoincrement())
  announcementId Int
  userId         String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model AnnouncementGrade {
  id             Int          @id @default(autoincrement())
  announcementId Int
  gradeId        Int
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  grade          Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([announcementId, gradeId])
}

model XeroTokens {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  tenantId     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("xero_tokens")
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String?
  recipientId String
  lessonId    Int?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lesson      Lesson?  @relation(fields: [lessonId], references: [id])

  @@map("notifications")
}

model StudentClass {
  id        Int      @id @default(autoincrement())
  studentId String
  classId   Int
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@index([studentId])
  @@index([classId])
}

model RecurringLesson {
  id              Int          @id @default(autoincrement())
  name            String
  rrule           String
  startTime       DateTime
  endTime         DateTime
  subjectId       Int
  classId         Int
  teacherId       String
  term            Int?
  year            Int?
  assessments     Assessment[]
  attendances     Attendance[]
  lessonInstances Lesson[]
  class           Class        @relation(fields: [classId], references: [id])
  subject         Subject      @relation(fields: [subjectId], references: [id])
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
}

model Note {
  id          String       @id @default(cuid())
  title       String?
  content     String
  author      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  date        DateTime
  userId      String
  actionItems ActionItem[]
  comments    Comment[]

  @@index([userId])
  @@index([date])
  @@map("notes")
  StudentTag StudentTag[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    String
  noteId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([userId])
}

model ActionItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  completed   Boolean   @default(false)
  noteId      String
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  author      String
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([userId])
}

model StudentStatusHistory {
  id         String         @id @default(cuid())
  studentId  String
  fromStatus StudentStatus?
  toStatus   StudentStatus
  changedAt  DateTime       @default(now())
  changedBy  String?
  reason     String?
  student    Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_status_history")
}

model StudentNote {
  id        String   @id @default(cuid())
  content   String   @db.Text
  author    String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentTag {
  id        String   @id @default(cuid())
  noteId    String
  studentId String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([noteId, studentId])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  price       Float
  date        DateTime
  userId      String 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@map("expenses")
}

model ChecklistItem {
  id          String        @id @default(cuid())
  text        String
  type        ChecklistType
  userId      String
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@map("checklist_items")
}

model PayRate {
  id          String   @id @default(cuid())
  name        String
  personType  String
  payRate     Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pay_rates")
}

model StaffReport {
  id          String   @id @default(cuid())
  staffId     String
  staffType   String
  subject     String
  content     String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([staffId])
  @@map("staff_reports")
}

model RecurringExpense {
  id          String   @id @default(cuid())
  description String
  price       Float
  frequency   String
  nextDate    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recurring_expenses")
}

model Schedule {
  id          String   @id @default(cuid())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  type        String   @default("event")
  rrule       String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("schedules")
}

model CashbookEntry {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  date      DateTime @default(now())
  xero      Boolean  @default(false)
  receipt   Boolean  @default(false)
  cashbook  Boolean  @default(false)
  addedBy   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("cashbook_entries")
}




enum ChatThreadType {
  CLASS
  DIRECT
}

model ChatThread {
  id           Int                     @id @default(autoincrement())
  type         ChatThreadType
  name         String?
  classId      Int?
  class        Class?                  @relation(fields: [classId], references: [id])
  messages     ChatMessage[]
  reads        ChatThreadRead[]
  participants ChatThreadParticipant[]
  createdBy    String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@map("chat_threads")
}

model ChatThreadParticipant {
  threadId Int
  userId   String
  role     String
  name     String     @default("")
  thread   ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@map("chat_thread_participants")
}

model ChatMessage {
  id         Int        @id @default(autoincrement())
  threadId   Int
  senderId   String
  senderName String
  content    String
  isDeleted  Boolean    @default(false)
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([threadId, createdAt])
  @@map("chat_messages")
}

model ChatThreadRead {
  threadId   Int
  userId     String
  lastReadAt DateTime   @default(now())
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@map("chat_thread_reads")
}

enum ChecklistType {
  DAILY
  MONTHLY
}

enum UserSex {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PaymentType {
  NO_PAYMENT
  BANK_TRANSFER
  CASH
}

enum StudentStatus {
  CURRENT
  TRIAL
  DISENROLLED
}

enum AssessmentType {
  EXAM
  ASSIGNMENT
}
